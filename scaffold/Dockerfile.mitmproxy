FROM mitmproxy/mitmproxy:latest

# Pre-install iptables and iproute2 so firewall.sh doesn't need apt-get at runtime.
# This eliminates the ~20s startup delay from installing packages on every container start.
USER root
RUN apt-get update -qq && \
    apt-get install -y -qq --no-install-recommends iptables iproute2 curl gosu && \
    rm -rf /var/lib/apt/lists/*
